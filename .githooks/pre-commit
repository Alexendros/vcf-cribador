#!/bin/sh
# Pre-commit hook: formatea y verifica lint antes de cada commit.

set -eu

echo "→ cargo fmt --check"
cargo fmt --check || {
    echo "⚠️  Formato incorrecto. Ejecuta 'cargo fmt' y vuelve a intentar."
    exit 1
}

echo "→ cargo clippy -- -D warnings"
cargo clippy --all-features -- -D warnings || {
    echo "⚠️  Clippy encontró problemas."
    exit 1
}

echo "✓ Pre-commit OK"
